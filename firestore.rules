rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper ---
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'chizobaezeh338@gmail.com';
    }

    // --- Users ---
    match /users/{uid} {
      allow read, update: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;

      // Orders subcollection
      match /orders/{orderId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null && request.auth.uid == uid
                      && request.resource.data.keys().hasAll(['type', 'customerName', 'status'])
                      && request.resource.data.status == 'pending'
                      && request.resource.data.total is number
                      && request.resource.data.customerName is string
                      && request.resource.data.customerName.size() <= 200;
        allow update, delete: if isAdmin();
      }
    }

    // Admin-legacy orders (admin creates orders for walk-in customers)
    match /users/admin-legacy/orders/{orderId} {
      allow read, write: if isAdmin();
    }

    // --- Product & Retail Categories (public read, admin write) ---
    match /productCategories/{categoryId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      // Authenticated users can update (for stock decrement during checkout)
      allow update: if isAdmin() || request.auth != null;
    }

    match /retailCategories/{categoryId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || request.auth != null;
    }

    // --- Testimonials ---
    match /testimonials/{docId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['name', 'rating'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() <= 200
                    && request.resource.data.rating is number
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5;
      allow update, delete: if isAdmin();
    }

    // --- Stock Notifications ---
    match /stockNotifications/{docId} {
      allow read: if isAdmin();
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['email', 'productId', 'productName'])
                    && request.resource.data.email is string
                    && request.resource.data.productId is string
                    && request.resource.data.productName is string;
    }

    // --- Gift Cards ---
    match /giftCards/{cardId} {
      allow read, write: if isAdmin();
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['code', 'type', 'amount', 'giftedTo'])
                    && request.resource.data.amount is number
                    && request.resource.data.amount > 0
                    && request.resource.data.code is string
                    && request.resource.data.giftedTo is string;
    }

    // --- Collection group query for admin to fetch all orders ---
    match /{path=**}/orders/{orderId} {
      allow read: if isAdmin();
    }
  }
}
