rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Anyone can view images (gallery, blog)
    match /{allPaths=**} {
      allow read: if true;
    }

    // Only admin can upload/delete
    match /gallery/{fileName} {
      allow write: if request.auth != null
                   && request.auth.token.email == 'chizobaezeh338@gmail.com'
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    match /blog/{fileName} {
      allow write: if request.auth != null
                   && request.auth.token.email == 'chizobaezeh338@gmail.com'
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
