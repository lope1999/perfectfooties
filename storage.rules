rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'chizobaezeh338@gmail.com' ||
        request.auth.token.email == 'perfectfooties@gmail.com' ||
        request.auth.token.email == 'praiseolusegun19@gmail.com'
      );
    }

    function isValidImage() {
      return request.resource.size < 10 * 1024 * 1024
          && request.resource.contentType.matches('image/.*');
    }

    // Public read for all files
    match /{allPaths=**} {
      allow read: if true;
    }

    // Admin-only write per folder
    match /products/{fileName} {
      allow write: if isAdmin() && isValidImage();
    }

    match /gallery/{fileName} {
      allow write: if isAdmin() && isValidImage();
    }

    match /blog/{fileName} {
      allow write: if isAdmin() && isValidImage();
    }

    match /niche-collections/{fileName} {
      allow write: if isAdmin() && isValidImage();
    }

    match /announcements/{fileName} {
      allow write: if isAdmin() && isValidImage();
    }

    match /collections/{collectionId}/{fileName} {
      allow write: if isAdmin() && isValidImage();
    }

    // Custom order reference photos — any authenticated user
    match /custom-orders/{userId}/{fileName} {
      allow write: if request.auth != null && isValidImage();
    }

    // Newsletter campaign images — admin only
    match /newsletters/{fileName} {
      allow write: if isAdmin() && isValidImage();
    }

  }
}
