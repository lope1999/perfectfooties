VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# EmailJS (optional — for sending confirmation emails from admin dashboard)
VITE_EMAILJS_SERVICE_ID=your-service-id
VITE_EMAILJS_PUBLIC_KEY=your-public-key
VITE_EMAILJS_ORDER_TEMPLATE_ID=template_order
VITE_EMAILJS_APPOINTMENT_TEMPLATE_ID=template_appointment

# Paystack (for 50% deposit payment on appointment booking)
VITE_PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxx

# Paystack secret key — stored as a Firebase Secret (NOT here in .env).
# Run: firebase functions:secrets:set PAYSTACK_SECRET_KEY
# Then paste your sk_live_xxx key when prompted.

# EmailJS appointment template — stored as a Firebase Secret (NOT here in .env).
# Run: firebase functions:secrets:set EMAILJS_APPOINTMENT_TEMPLATE_ID
# Then paste the template ID for your appointment confirmation email.
